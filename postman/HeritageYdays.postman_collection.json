{
  "info": {
    "name": "HeritageYdays API Smoke",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Smoke tests backend HeritageYdays for local and CI (Newman)."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "testUserEmail", "value": "ci-user@example.com" },
    { "key": "testUserPassword", "value": "Password123!" },
    { "key": "testUserDisplayName", "value": "CI User" },
    { "key": "authToken", "value": "" },
    { "key": "createdStoryId", "value": "" },
    { "key": "createdCircleId", "value": "" },
    { "key": "createdFolderId", "value": "" },
    { "key": "friendTargetUserId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /actuator/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Health status is UP', function () {",
                  "  pm.expect(body.status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"{{testUserDisplayName}}\",\n  \"email\": \"{{testUserEmail}}\",\n  \"password\": \"{{testUserPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register returns 200/201/400/409 (already exists tolerated)', function () {",
                  "  pm.expect([200, 201, 400, 409]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testUserEmail}}\",\n  \"password\": \"{{testUserPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Login response contains token', function () {",
                  "  pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('authToken', body.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login (invalid credentials)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testUserEmail}}\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid login returns 4xx', function () {",
                  "  pm.expect(pm.response.code).to.be.within(400, 499);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET /api/users/me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get me status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT /api/users/me",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"{{testUserDisplayName}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Update me status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Stories",
      "item": [
        {
          "name": "GET /api/stories",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/stories"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Stories feed status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/stories",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"CI smoke story {{testUserDisplayName}}\",\n  \"content\": \"Automated smoke story content\",\n  \"resume\": \"Smoke story\",\n  \"visibility\": \"PUBLIC\",\n  \"mainTheme\": \"OTHER\",\n  \"tags\": [\"ci\", \"smoke\"],\n  \"isPublished\": true\n}"
            },
            "url": "{{baseUrl}}/api/stories"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create story returns 200/201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body && body.id) {",
                  "  pm.collectionVariables.set('createdStoryId', body.id);",
                  "}",
                  "pm.test('createdStoryId is available', function () {",
                  "  pm.expect(pm.collectionVariables.get('createdStoryId')).to.be.ok;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/stories/{id}",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/stories/{{createdStoryId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get story detail status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/stories/{id}/save",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/stories/{{createdStoryId}}/save"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Toggle save returns 200/204', function () {",
                  "  pm.expect([200, 204]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
