    {
      "name": "Negative cases",
      "item": [
        {
          "name": "GET /api/users/me (without auth)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Without auth returns 401/403', function () {",
                  "  pm.expect([401, 403]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
